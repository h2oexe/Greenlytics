{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=greenlytics;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Secret": "CHANGE_THIS_TO_A_STRONG_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "Greenlytics",
    "Audience": "Greenlytics",
    "ExpiryMinutes": "15"
  },
  "Email": {
    "Host": "localhost",
    "Port": "1025",
    "From": "noreply@greenlytics.app",
    "Username": "",
    "Password": "",
    "UseSsl": "false"
  },
  "Minio": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "greenlytics-exports",
    "UseSsl": "false"
  },
  "Stripe": {
    "SecretKey": "sk_test_REPLACE_WITH_YOUR_STRIPE_KEY",
    "WebhookSecret": "whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET"
  },
  "AppUrl": "http://localhost:3000",
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      { "Endpoint": "*", "Period": "1m", "Limit": 100 },
      { "Endpoint": "*/api/auth/login", "Period": "1m", "Limit": 10 },
      { "Endpoint": "*/api/auth/register", "Period": "1h", "Limit": 5 },
      { "Endpoint": "*/api/export/*", "Period": "1m", "Limit": 5 }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
